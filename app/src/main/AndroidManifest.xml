<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-feature android:name="android.hardware.type.watch" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!--
               Set to true if your app is Standalone, that is, it does not require the handheld
               app to run.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <!-- Enable data layer sync with phone app -->
        <meta-data
            android:name="com.google.android.wearable.beta.app.ENABLE_SYNC"
            android:value="true" />

        <service
            android:name=".service.WatchReceiverService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <!-- Phone sends handshake_ack as DataItem after receiving our handshake_response -->
                <data android:scheme="wear" android:host="*" android:pathPrefix="/handshake_ack" />
                <!-- Phone publishes ACKs to /state/phone -->
                <data android:scheme="wear" android:host="*" android:pathPrefix="/state/phone" />
                <!-- Legacy handshake path (keep for backward compatibility) -->
                <data android:scheme="wear" android:host="*" android:pathPrefix="/handshake_request" />
            </intent-filter>
            <!-- Separate intent-filter for MESSAGE_RECEIVED (pong) -->
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/pong" />
            </intent-filter>
        </service>

        <!-- Workout message receiver service -->
        <service
            android:name=".workout.WorkoutMessageReceiverService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/workout/push" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/workout/start" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/workout/state_request" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/workout/event" />
            </intent-filter>
        </service>

        <!-- Workout foreground service -->
        <service
            android:name=".workout.service.WorkoutService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="health" />

        <!-- Workout notification action receiver -->
        <receiver
            android:name=".workout.WorkoutNotificationActionReceiver"
            android:exported="false" />

        <!-- Habit reminder message receiver -->
        <service
            android:name=".habit.HabitMessageReceiverService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/habit/reminder/start" />
            </intent-filter>
        </service>

        <!-- Habit reminder foreground service -->
        <service
            android:name=".habit.HabitService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Habit retry alarm receiver -->
        <receiver
            android:name=".habit.HabitAlarmReceiver"
            android:exported="false" />

        <service
            android:name=".service.SensorForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="health" />

        <service
            android:name=".service.HeartRateForegroundService"
            android:exported="false"
            android:foregroundServiceType="health" />

        <activity
            android:name="com.example.sensorstreamerwearos.MainActivity"
            android:exported="true"
            android:theme="@style/RedirectTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".workout.ui.WorkoutTimerActivity"
            android:exported="false"
            android:theme="@style/Theme.WorkoutTimer" />

        <activity
            android:name=".habit.HabitReminderActivity"
            android:exported="false"
            android:theme="@style/Theme.WorkoutTimer" />
    </application>

</manifest>